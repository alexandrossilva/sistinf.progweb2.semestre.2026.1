<!DOCTYPE html>
<html lang="pt-BR">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sequência de Números</title>
</head>
<body>
    <h1>Sequência de Números</h1>
    <ul>
        <% for (let i = 0; i < numeros.length; i++) { %>
            <li><%= numeros[i] %></li>
        <% } %>
    </ul>
</body>
</html>